---
import { installModes } from '../data/install';

const defaultMode = installModes.find((m) => m.isDefault) ?? installModes[0];
---

<section class="install section-pad" aria-labelledby="install-title">
  <div class="install-inner">
    <div class="eyebrow">Installation</div>
    <h1 id="install-title" class="install-h1">Pick your deployment profile.</h1>
    <p class="install-lead">
      Solo is the recommended default. All modes share the same vault and MCP stub —
      they differ in services started, LLM provider, and access pattern.
    </p>

    <!-- Installation — 3 voies -->
    <div class="install-oneliner">
      <div class="eyebrow block-label">Get started — v0.4.3 · Linux x86_64</div>

      <div class="install-ways">

        <!-- Voie 1 — Binaires pré-compilés (recommandé) -->
        <div class="install-way install-way--primary">
          <div class="install-way-header">
            <div class="eyebrow install-way-label">Pre-built binaries</div>
            <span class="install-way-badge">recommended</span>
          </div>
          <p class="install-way-desc">
            Three archives — download only what your deployment needs.
            Linux x86_64. SHA256 and SLSA provenance attestation per archive.
          </p>

          <div class="install-archives">
            <div class="install-archive">
              <div class="install-archive-role">
                <span class="install-archive-name">gradatum-server</span>
                <span class="install-archive-badge">backbone vault</span>
              </div>
              <p class="install-archive-desc">
                Contains <code>gradatum-server</code>, <code>gradatum-worker</code>, <code>gradatum-admin</code>.
                Core vault store, job queue, admin CLI.
              </p>
              <pre class="install-pre install-archive-pre"><code>gradatum-server-v0.4.3-x86_64-unknown-linux-gnu.tar.gz</code></pre>
            </div>

            <div class="install-archive">
              <div class="install-archive-role">
                <span class="install-archive-name">gradatum-llm</span>
                <span class="install-archive-badge">LLM layer</span>
              </div>
              <p class="install-archive-desc">
                Contains <code>gradatum-gateway</code> and <code>gradatum-engine</code>.
                Router, circuit-breaker, llama-server supervisor. Required for local inference.
              </p>
              <pre class="install-pre install-archive-pre"><code>gradatum-llm-v0.4.3-x86_64-unknown-linux-gnu.tar.gz</code></pre>
            </div>

            <div class="install-archive">
              <div class="install-archive-role">
                <span class="install-archive-name">gradatum-mcp</span>
                <span class="install-archive-badge">agent bridge</span>
              </div>
              <p class="install-archive-desc">
                Contains <code>gradatum-mcp-stub</code>.
                MCP bridge for agent clients (Claude Code, Claude Desktop, etc.).
              </p>
              <pre class="install-pre install-archive-pre"><code>gradatum-mcp-v0.4.3-x86_64-unknown-linux-gnu.tar.gz</code></pre>
            </div>
          </div>

          <div class="install-release-footer">
            <a
              href="https://github.com/gradatum/gradatum/releases"
              target="_blank"
              rel="noopener noreferrer"
              class="install-release-link"
            >github.com/gradatum/gradatum/releases →</a>
            <span class="install-release-meta">SHA256SUMS · SLSA attestation per archive</span>
          </div>

          <div class="install-verify-block">
            <div class="eyebrow install-source-label">Verify integrity</div>
            <pre class="install-pre install-source-pre"><code><span class="install-comment"># verify SHA256 (example — server archive)</span>
sha256sum -c SHA256SUMS --ignore-missing

<span class="install-comment"># verify SLSA build provenance (GitHub native)</span>
gh attestation verify \
  gradatum-server-v0.4.3-x86_64-unknown-linux-gnu.tar.gz \
  --repo gradatum/gradatum</code></pre>
          </div>
        </div>

        <!-- Voies 2 + 3 en ligne -->
        <div class="install-ways-secondary">

          <!-- Voie 2 — crates.io SDK -->
          <div class="install-way">
            <div class="install-way-header">
              <div class="eyebrow install-way-label">Via crates.io</div>
              <span class="install-way-badge install-way-badge--secondary">Rust SDK</span>
            </div>
            <p class="install-way-desc">
              Embed gradatum as a library dependency in your Rust project.
              28 crates in the workspace — <code>gradatum</code> is the umbrella entry point.
            </p>
            <pre class="install-pre install-source-pre"><code>cargo add gradatum  <span class="install-comment"># umbrella SDK</span></code></pre>
            <p class="install-source-note">
              <a href="https://crates.io/crates/gradatum" target="_blank" rel="noopener noreferrer">crates.io/crates/gradatum</a>
              · 28 crates · Apache-2.0
            </p>
          </div>

          <!-- Voie 3 — Build from source -->
          <div class="install-way">
            <div class="install-way-header">
              <div class="eyebrow install-way-label">Build from source</div>
              <span class="install-way-badge install-way-badge--secondary">full control</span>
            </div>
            <p class="install-way-desc">
              Clone the repository and compile all workspace crates.
              Requires recent stable Rust (MSRV).
            </p>
            <pre class="install-pre install-source-pre"><code>git clone https://github.com/gradatum/gradatum
cd gradatum &amp;&amp; cargo build --release --workspace</code></pre>
            <p class="install-source-note">
              <a href="https://github.com/gradatum/gradatum" target="_blank" rel="noopener noreferrer">github.com/gradatum/gradatum</a>
              · Apache-2.0 · Rust 2021 · MSRV 1.88+
            </p>
          </div>

        </div>

      </div>

      <p class="install-alpha-notice">
        v0.4.3 · Linux x86_64 · API not stable before v1.0. See
        <a href="https://github.com/gradatum/gradatum/blob/main/docs/DEPLOYMENT.md" target="_blank" rel="noopener noreferrer">docs/DEPLOYMENT.md</a>
        for the full deployment reference.
      </p>
    </div>

    <!-- CSS-only tabs (radio + :has selector, zero JS) -->
    <fieldset class="mode-tabs" aria-label="Installation modes">
      <legend class="sr-only">Select an installation mode</legend>

      {installModes.map((mode) => (
        <input
          type="radio"
          id={`tab-${mode.id}`}
          name="install-mode"
          value={mode.id}
          checked={mode.id === defaultMode.id}
          class="tab-radio"
        />
      ))}

      <div class="tab-rail" role="tablist">
        {installModes.map((mode) => (
          <label for={`tab-${mode.id}`} class="tab-label" role="tab" tabindex="0">
            <span class="tab-name">{mode.name}{mode.isDefault ? ' ★' : ''}</span>
            <span class="tab-level">{mode.level}</span>
          </label>
        ))}
      </div>

      <div class="tab-panels">
        {installModes.map((mode) => (
          <div
            id={`panel-${mode.id}`}
            class={`tab-panel panel-${mode.id}`}
            role="tabpanel"
            aria-labelledby={`tab-${mode.id}`}
          >
            <div class="panel-header">
              <h3 class="panel-name">
                {mode.name}{mode.isDefault ? ' ★' : ''}
                <span class="panel-level">{mode.level}</span>
              </h3>
              {mode.status === 'planned-v0.5' && (
                <span class="status-badge status-planned" aria-label="Planned for v0.5.0">
                  planned for v0.5
                </span>
              )}
              {mode.status === 'planned-v0.5.1' && (
                <span class="status-badge status-planned" aria-label="Planned for v0.5.1">
                  planned for v0.5.1
                </span>
              )}
              {mode.status === 'planned-v1.0' && (
                <span class="status-badge status-planned" aria-label="Planned for v1.0.0">
                  planned for v1.0.0
                </span>
              )}
            </div>

            <p class="panel-tagline">{mode.tagline}</p>
            <p class="panel-usecase"><strong>Use case</strong> — {mode.useCase}</p>

            <pre class="install-pre panel-command"><code>{mode.command}</code></pre>

            <dl class="panel-specs">
              <dt>Services</dt>
              <dd>{mode.services.join(' · ')}</dd>
              <dt>LLM</dt>
              <dd>{mode.llm}</dd>
              <dt>MCP access</dt>
              <dd>
                {mode.mcpAccess === 'both'
                  ? 'stub + Remote OAuth'
                  : mode.mcpAccess === 'remote-oauth'
                    ? 'Remote OAuth'
                    : 'stub'}
              </dd>
            </dl>
          </div>
        ))}
      </div>
    </fieldset>

    <!-- Supported providers table -->
    <div class="install-providers">
      <div class="eyebrow block-label">Supported LLM providers</div>
      <table class="providers-table">
        <thead>
          <tr>
            <th scope="col">Provider</th>
            <th scope="col">Flag</th>
            <th scope="col">Requirement</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Ollama (local)</td>
            <td><code>--provider ollama</code></td>
            <td>Ollama installed and running</td>
          </tr>
          <tr>
            <td>llama.cpp server</td>
            <td><code>--provider llamacpp --llm-url URL</code></td>
            <td>llama.cpp server accessible</td>
          </tr>
          <tr>
            <td>OpenRouter</td>
            <td><code>--provider openrouter --api-key KEY</code></td>
            <td>OpenRouter API key</td>
          </tr>
          <tr>
            <td>Anthropic</td>
            <td><code>--provider anthropic --api-key KEY</code></td>
            <td>Anthropic API key</td>
          </tr>
          <tr>
            <td>OpenAI</td>
            <td><code>--provider openai --api-key KEY</code></td>
            <td>OpenAI API key</td>
          </tr>
          <tr>
            <td>Custom OpenAI-compatible</td>
            <td><code>--provider custom --llm-url URL</code></td>
            <td>Accessible endpoint</td>
          </tr>
          <tr>
            <td>None (Nano mode)</td>
            <td><code>--level nano</code></td>
            <td>—</td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Post-install commands -->
    <div class="install-postinstall">
      <div class="eyebrow block-label">Post-install commands</div>
      <pre class="install-pre"><code>gradatum-admin init --preset hierarchical --root /var/lib/gradatum

gradatum-admin api-key create --root /var/lib/gradatum --owner mcp-stub
gradatum-admin api-key list   --root /var/lib/gradatum

gradatum-admin jobs list --root /var/lib/gradatum
gradatum-admin jobs dlq  --root /var/lib/gradatum

gradatum-admin vault rename "old title" "new title"  # F-39 stable wikilinks</code></pre>
    </div>

    <!-- Example topology -->
    <div class="install-topology">
      <div class="eyebrow block-label">Example topology — multi-host GPU serving</div>
      <p class="install-topology-desc">
        Single-binary on one box, or scale out: one GPU host serving several models,
        an app host routing through the gateway with automatic CPU fallback.
      </p>

      <!-- SVG diagram (default) — mirrors ArchDiagram conventions -->
      <div class="diagram-svg topo-diagram" aria-label="Deployment topology diagram" role="img">
        <svg
          viewBox="0 0 900 482"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          focusable="false"
          class="topo-svg"
        >
          <defs>
            <marker id="topo-arrow" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
              <path d="M0,0 L0,6 L8,3 z" fill="var(--ink-soft)" />
            </marker>
            <marker id="topo-arrow-accent" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
              <path d="M0,0 L0,6 L8,3 z" fill="var(--accent)" />
            </marker>
          </defs>

          <!-- ── Row 0: CONSUMERS ── -->
          <rect x="10" y="10" width="880" height="44" rx="0"
                fill="none" stroke="var(--rule)" stroke-width="1"/>
          <text x="24" y="27" class="svg-label-mono">CONSUMERS</text>
          <text x="24" y="45" class="svg-label-sm">apps · agents · MCP clients</text>
          <text x="660" y="38" class="svg-label-proto">MCP / HTTP / REST</text>

          <!-- Arrow consumers → app-host -->
          <line x1="450" y1="54" x2="450" y2="84"
                stroke="var(--ink-soft)" stroke-width="1.5" marker-end="url(#topo-arrow)"/>

          <!-- ── Row 1: APP-HOST swimlane ── -->
          <rect x="10" y="88" width="880" height="162" rx="0"
                fill="color-mix(in srgb, var(--rule) 18%, transparent)"
                stroke="var(--rule)" stroke-width="1"/>
          <text x="24" y="106" class="svg-label-mono">APP-HOST  ·  Linux</text>

          <!-- gradatum-server -->
          <rect x="30" y="116" width="220" height="40" rx="0"
                fill="none" stroke="var(--rule)" stroke-width="1.5"/>
          <text x="44" y="140" class="svg-box-main">gradatum-server</text>
          <text x="44" y="152" class="svg-box-sub">:19090 · /api/v1 · /mcp</text>

          <!-- gradatum-worker -->
          <rect x="270" y="116" width="220" height="40" rx="0"
                fill="none" stroke="var(--rule)" stroke-width="1.5"/>
          <text x="284" y="140" class="svg-box-main">gradatum-worker</text>
          <text x="284" y="152" class="svg-box-sub">curator · maintenance</text>

          <!-- Arrow server+worker → gateway -->
          <line x1="490" y1="136" x2="535" y2="136"
                stroke="var(--ink-soft)" stroke-width="1.5" marker-end="url(#topo-arrow)"/>

          <!-- gradatum-gateway (accent — key routing element) -->
          <rect x="538" y="116" width="342" height="40" rx="0"
                fill="none" stroke="var(--accent)" stroke-width="1.5"/>
          <text x="552" y="140" class="svg-box-main">gradatum-gateway  :8436</text>
          <text x="552" y="152" class="svg-box-sub">router · circuit-breaker</text>

          <!-- local CPU fallback box -->
          <rect x="538" y="176" width="342" height="36" rx="0"
                fill="none" stroke="var(--rule)" stroke-width="1"/>
          <text x="552" y="196" class="svg-box-main">local CPU fallback</text>
          <text x="552" y="208" class="svg-box-sub">engine + embedder</text>

          <!-- Arrow gateway → fallback (fallback path, dashed) -->
          <line x1="709" y1="156" x2="709" y2="176"
                stroke="var(--ink-soft)" stroke-width="1"
                stroke-dasharray="3 3"
                marker-end="url(#topo-arrow)"/>
          <text x="716" y="170" class="svg-label-proto">fallback</text>

          <!-- Arrow primary: gateway bottom-left → out of app-host (toward gpu-host) -->
          <line x1="570" y1="156" x2="570" y2="250"
                stroke="var(--accent)" stroke-width="1.5" marker-end="url(#topo-arrow-accent)"/>
          <text x="576" y="170" class="svg-label-proto">primary</text>

          <!-- ── LAN separator label ── -->
          <text x="440" y="272" class="svg-label-mono" text-anchor="middle">LAN</text>
          <line x1="10" y1="262" x2="425" y2="262"
                stroke="var(--rule)" stroke-width="1" stroke-dasharray="4 4"/>
          <line x1="455" y1="262" x2="890" y2="262"
                stroke="var(--rule)" stroke-width="1" stroke-dasharray="4 4"/>

          <!-- ── Row 2: GPU-HOST swimlane ── -->
          <rect x="10" y="280" width="880" height="162" rx="0"
                fill="color-mix(in srgb, var(--rule) 10%, transparent)"
                stroke="var(--rule)" stroke-width="1"/>
          <text x="24" y="298" class="svg-label-mono">GPU-HOST  ·  Linux</text>
          <text x="300" y="298" class="svg-label-sm">gradatum-engine · one supervisor binary, one instance per model</text>

          <!-- 5 model boxes — evenly spaced, width=160, gap=12 -->
          <!-- chat :8083 — x=30 -->
          <rect x="30" y="308" width="158" height="36" rx="0"
                fill="none" stroke="var(--rule)" stroke-width="1"/>
          <text x="44" y="328" class="svg-box-main">chat  :8083</text>
          <text x="44" y="340" class="svg-box-sub">llama-server child</text>

          <!-- embed :8432 — x=200 -->
          <rect x="200" y="308" width="158" height="36" rx="0"
                fill="none" stroke="var(--rule)" stroke-width="1"/>
          <text x="214" y="328" class="svg-box-main">embed  :8432</text>
          <text x="214" y="340" class="svg-box-sub">llama-server child</text>

          <!-- small :8082 — x=370 -->
          <rect x="370" y="308" width="158" height="36" rx="0"
                fill="none" stroke="var(--rule)" stroke-width="1"/>
          <text x="384" y="328" class="svg-box-main">small  :8082</text>
          <text x="384" y="340" class="svg-box-sub">llama-server child</text>

          <!-- reason :8081 — x=540 -->
          <rect x="540" y="308" width="158" height="36" rx="0"
                fill="none" stroke="var(--rule)" stroke-width="1"/>
          <text x="554" y="328" class="svg-box-main">reason  :8081</text>
          <text x="554" y="340" class="svg-box-sub">llama-server child</text>

          <!-- vision :8080 — x=710 -->
          <rect x="710" y="308" width="170" height="36" rx="0"
                fill="none" stroke="var(--rule)" stroke-width="1"/>
          <text x="724" y="328" class="svg-box-main">vision  :8080</text>
          <text x="724" y="340" class="svg-box-sub">+mmproj · llama-server child</text>

          <!-- GPU-host annotations -->
          <text x="30" y="368" class="svg-label-proto">each instance supervises one llama-server child (loopback)</text>
          <text x="30" y="382" class="svg-label-proto">GGUF models bind-mounted read-only  ·  /opt/gradatum/models/</text>

          <!-- Primary path arrow arrives at gpu-host top -->
          <line x1="570" y1="250" x2="570" y2="280"
                stroke="var(--accent)" stroke-width="1.5" marker-end="url(#topo-arrow-accent)"/>

          <!-- ── Bottom annotation ── -->
          <text x="450" y="462" class="svg-label-proto" text-anchor="middle">primary → GPU host  ·  fallback → local CPU (circuit-breaker auto)</text>
        </svg>
      </div>

      <!-- ASCII fallback (shown when data-diagram="ascii") -->
      <pre class="diagram-ascii topo-ascii" aria-label="ASCII deployment topology diagram">
  consumers (apps · agents · MCP clients)
               ↓  MCP / HTTP / REST
  ┌──────────────────── app-host (Linux) ───────────────────────┐
  │  gradatum-server ─┐                                         │
  │  gradatum-worker ─┴──────────▶ gradatum-gateway :8436       │
  │                                (router · circuit-breaker)   │
  │                                  │ primary       │ fallback │
  │                                  ▼               ▼          │
  │                            [GPU-HOST]   local CPU fallback  │
  └──────────────────────────────────┼────────────────────────┘
                                   LAN
  ┌──────────────────── gpu-host (Linux) ───────────────────────┐
  │  gradatum-engine · one supervisor binary, one instance/model│
  │   chat :8083 · embed :8432 · small :8082                    │
  │   reason :8081 · vision :8080 (+mmproj)                     │
  │   each instance supervises one llama-server child (loopback) │
  │   GGUF bind-mounted ro · /opt/gradatum/models/              │
  └─────────────────────────────────────────────────────────────┘
  primary → GPU host · fallback → local CPU (circuit-breaker auto)</pre>

      <p class="install-topology-note">
        Full deployment guide and configuration reference:
        <a href="https://github.com/gradatum/gradatum/blob/main/docs/DEPLOYMENT.md" class="topology-link">docs/DEPLOYMENT.md</a>.
      </p>
    </div>
  </div>
</section>

<style>
  /* Screen-reader only utility */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .install {
    background: var(--paper);
  }

  .install-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .install-h1 {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 500;
    margin-top: 1rem;
    line-height: 1.05;
  }

  .install-lead {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--ink-soft);
    margin-top: 1.5rem;
    max-width: 720px;
    line-height: 1.6;
  }

  /* ── Install — 3 voies ──────────────────────────────────────────────────── */

  .install-oneliner {
    margin-top: 3rem;
  }

  /* Grid: primary (binaires) full-width, puis 2 colonnes pour crates/source */
  .install-ways {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 1.25rem;
  }

  /* Voie individuelle */
  .install-way {
    border: 1px solid var(--rule);
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Voie primaire — accent border */
  .install-way--primary {
    border-color: var(--accent);
  }

  .install-way-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .install-way-label {
    letter-spacing: 0.18em;
    margin: 0;
  }

  .install-way-badge {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0.2rem 0.65rem;
    border: 1px solid var(--accent);
    color: var(--accent);
    border-radius: 999px;
    white-space: nowrap;
  }

  .install-way-badge--secondary {
    border-color: var(--rule);
    color: var(--muted);
  }

  .install-way-desc {
    font-size: 0.9rem;
    color: var(--ink-soft);
    line-height: 1.6;
    margin: 0;
  }

  /* Grille archives */
  .install-archives {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .install-archive {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    border-left: 2px solid var(--rule);
    padding-left: 1rem;
  }

  .install-archive-role {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .install-archive-name {
    font-family: var(--font-mono);
    font-size: 0.78125rem;
    color: var(--ink);
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  .install-archive-badge {
    font-family: var(--font-mono);
    font-size: 0.5625rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    white-space: nowrap;
  }

  .install-archive-desc {
    font-size: 0.8125rem;
    color: var(--ink-soft);
    line-height: 1.55;
    margin: 0;
  }

  .install-archive-pre {
    margin: 0;
  }

  .install-archive-pre code {
    font-size: 0.6875rem;
    word-break: break-all;
  }

  /* Release footer + vérif */
  .install-release-footer {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding-top: 0.5rem;
    border-top: 1px solid var(--rule);
  }

  .install-release-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    color: var(--accent);
    text-decoration: none;
    transition: opacity 0.12s ease;
  }

