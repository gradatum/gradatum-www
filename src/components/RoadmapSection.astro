const stateLabel: Record<Phase['state'], string> = {
  done: '✓ shipped',
  'in-progress': '⚡ IN PROGRESS',
  next: 'in flight',
  todo: 'planned',
};
---
<section id="roadmap" class="roadmap section-pad section-gap" aria-labelledby="roadmap-title">
  <div class="roadmap-inner">
    <div class="eyebrow">VI · Status & Roadmap</div>
    <h2 id="roadmap-title" class="roadmap-h2">Roadmap — phases shipped and in flight</h2>
    <p class="roadmap-meta">
      <code>v0.1.0-alpha.13</code> · 796 tests · 26 crates · Rust 2021 · MSRV 1.85
    </p>

    <div class="phases-list" role="list">
      {phases.map((p) => (
        <div class={`phase-row state-${p.state}`} role="listitem">
          <div class="phase-num" aria-hidden="true">
            {p.num}
          </div>

          <div class="phase-body">
            <div class="phase-header">
              <div>
                <div class="phase-title">{p.title}</div>
                <div class="phase-subtitle">{p.subtitle}</div>
              </div>
              {p.tag && (
                <span class="phase-tag">{p.tag}</span>
              )}
            </div>

            <ul class="phase-deliverables" role="list">
              {p.deliverables.map((d) => (
                <li>{d}</li>
              ))}
            </ul>
          </div>

          <div class={`phase-status status-${p.state}`} aria-label={`Status: ${stateLabel[p.state]}`}>
            {stateLabel[p.state]}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .roadmap {
    background: var(--paper);
  }

  .roadmap-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .roadmap-h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 3.5vw, 2.875rem);
    font-weight: 500;
    margin-top: 1rem;
  }

  .roadmap-meta {
    margin-top: 1rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--muted);
  }

  /* Phase rows */
  .phases-list {
    margin-top: 3.5rem;
    display: flex;
    flex-direction: column;
  }

  .phase-row {
    display: grid;
    grid-template-columns: 7rem 1fr 8rem;
    gap: 2rem;
    padding: 1.75rem 0;
    border-top: 1px solid var(--rule);
    align-items: start;
  }

  /* Large italic phase number */
  .phase-num {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 0.9;
    color: var(--muted);
  }

  .state-done .phase-num {
    color: var(--accent);
  }

  .phase-title {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.1;
  }

  .phase-subtitle {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
    letter-spacing: 0.08em;
    margin-top: 0.375rem;
  }

  .phase-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .phase-tag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 0.2em 0.6em;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .phase-deliverables {
    list-style: none;
    margin-top: 0.875rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .phase-deliverables li {
    font-size: 0.9375rem;
    color: var(--ink-soft);
    line-height: 1.5;
  }

  .phase-deliverables li::before {
    content: '— ';
    color: var(--rule);
  }

  /* Status badge */
  .phase-status {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-align: right;
    color: var(--muted);
    padding-top: 0.5rem;
  }

  .status-done {
    color: var(--accent);
  }

  .status-in-progress {
    color: var(--accent);
    font-weight: 700;
  }

  .state-in-progress .phase-num {
    color: var(--accent);
    font-weight: 700;
  }

  .state-in-progress .phase-title {
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .phase-row {
      grid-template-columns: 4rem 1fr;
      grid-template-rows: auto auto;
    }

    .phase-status {
      grid-column: 2;
      text-align: left;
      padding-top: 0.5rem;
    }
  }
</style>
