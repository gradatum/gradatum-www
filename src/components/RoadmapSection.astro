---
// Roadmap — source: ../gradatum/docs/PHASES.md
// Décomposition Phase 2 : P2.0 / P2.1 quality / P2.1.1 hardening / P2.1.2 soft archiving / P2.2 production hardening / P2.3 skill agent
// Phase 1 = DONE (v0.1.0-alpha, 244 tests, 22 crates)
// Phase 2.0 = DONE (v0.1.0-alpha.5 — service mode shipped 2026-05-07)
// Phase 2.1 = DONE (v0.1.0-alpha.7 — quality & robustness, 2026-05-08)
// Phase 2.1.1 = DONE (v0.1.0-alpha.8 — hardening + semantic search, 2026-05-09)
// Phase 2.1.2 = DONE (v0.1.0-alpha.9-patch.1 — soft archiving + memory hygiene, 2026-05-09)
// Phase 2.2 = next (Production hardening — quality before public release)
// Phase 2.3 / 3 / 4 = planned

interface Phase {
  num: string;
  title: string;
  subtitle: string;
  state: 'done' | 'next' | 'todo';
  deliverables: string[];
  tag?: string;
}

const phases: Phase[] = [
  {
    num: '1',
    title: 'Functional core',
    subtitle: 'DONE · v0.1.0-alpha · les fondations',
    state: 'done',
    tag: 'v0.1.0-alpha',
    deliverables: [
      'Le moteur — 22 modules pour stocker, indexer et retrouver des notes',
      'Stockage local fiable — base SQLite + recherche plein-texte (FTS5 + Tantivy)',
      'Recherche par pertinence — algorithmes BM25 et PageRank pour trier les résultats',
      'Multi-stockage flexible — disque local, NAS, futurs backends cloud',
      '244 tests automatisés couvrant le code',
    ],
  },
  {
    num: '2.0',
    title: 'Service mode',
    subtitle: 'DONE · v0.1.0-alpha.5 · service mode shipped',
    state: 'done',
    tag: 'v0.1.0-alpha.5',
    deliverables: [
      'Serveur HTTP — gradatum tourne en service, 13 outils exposés (lecture + écriture)',
      'Compatible Claude Code & ZeroClaw via passerelle MCP',
      'Authentification sécurisée — clés API + jetons JWT (1h humain, 24h service)',
      'Travailleur de fond — classement automatique des notes par LLM',
      'Outil admin — initialiser, sauvegarder, restaurer un vault',
      'Installation automatisée — script de déploiement reproductible',
    ],
  },
  {
    num: '2.1',
    title: 'Quality & robustness',
    subtitle: 'DONE · v0.1.0-alpha.7 · finitions production · 2026-05-08',
    state: 'done',
    tag: 'v0.1.0-alpha.7',
    deliverables: [
      'Suivi des opérations — l\'API renvoie le vrai statut (en cours, terminé, en erreur)',
      'Recherche fidèle — tri par pertinence réelle BM25 (au lieu d\'un proxy approximatif)',
      'Messages d\'erreur sûrs — pas de fuite d\'informations système',
      'Configuration plus lisible — paramètres canoniques, ancien format toujours accepté',
    ],
  },
  {
    num: '2.1.1',
    title: 'Hardening & semantic search',
    subtitle: 'DONE · v0.1.0-alpha.8 · sécurité réseau + recherche sémantique · 2026-05-09',
    state: 'done',
    tag: 'v0.1.0-alpha.8',
    deliverables: [
      'Garde réseau gradatum-warden — limitation de débit + filtrage IP, protection anti-abus',
      'Authentification optionnelle — flag pour exiger un jeton sur le suivi de jobs',
      'Recherche sémantique automatique — chaque note reçoit son empreinte vectorielle (1024 dimensions) à la création',
      'Outil de rattrapage — recalculer les empreintes sur la base existante en lots',
      '591 tests automatisés (+45)',
    ],
  },
  {
    num: '2.1.2',
    title: 'Soft archiving & memory hygiene',
    subtitle: 'DONE · v0.1.0-alpha.9 + patch.1 · archivage doux · 2026-05-09',
    state: 'done',
    tag: 'v0.1.0-alpha.9-patch.1',
    deliverables: [
      'Archivage sans suppression (vault_downgrade) — marquer une note obsolète tout en conservant son contenu',
      'Recherche par défaut propre — les notes archivées sont automatiquement exclues',
      'Recherche élargie optionnelle — paramètre include_downgraded pour fouiller dans les archives, classées en bas par pénalité de score',
      'Restauration — réactiver une note archivée par simple appel HTTP',
      'Lien de remplacement — chaque note archivée peut pointer vers celle qui la remplace',
      'Outil de migration — importer en bloc depuis une mémoire vault-mem externe',
      'Sanitization recherche — caractères spéciaux (. \' -) dans les requêtes correctement échappés',
      '698 tests automatisés (+107 cumulé Phase 2.1.x)',
    ],
  },
  {
    num: '2.2',
    title: 'Production hardening',
    subtitle: 'qualité avant ouverture publique',
    state: 'next',
    deliverables: [
      'Tests étendus — couverture des cas Unicode, accents, requêtes complexes',
      'Optimisations performance — préparation aux migrations de gros volumes',
      'Audit trace — historique des opérations sensibles (archivage, restauration)',
      'Documentation publique complète',
      'Période d\'usage réel — ≥ 30 jours en production avant ouverture v0.1.0 public',
    ],
  },
  {
    num: '2.3',
    title: 'Skill agent',
    subtitle: 'gradatum-usage pour Claude Code & ZeroClaw',
    state: 'next',
    deliverables: [
      'Mode d\'emploi pour les agents IA — comment écrire et chercher proprement',
      '11 catégories canoniques — taxonomie unique pour toute la mémoire',
      'Synchronisation multi-source — agents + skill registries',
      'Validation par council et expérience terrain (≥ 30 jours)',
    ],
  },
  {
    num: '3',
    title: 'Index v2',
    subtitle: 'nouveau cap de qualité de recherche',
    state: 'todo',
    deliverables: [
      'Recherche vectorielle accélérée (HNSW) sur les empreintes',
      'Migration full-text vers Tantivy',
      'Fusion intelligente des deux types de recherche + reclassement final',
      'Métriques Prometheus + traces JSON',
      'Objectif : +30% de pertinence mesurée vs v1',
    ],
  },
  {
    num: '4',
    title: 'Polish',
    subtitle: 'production-ready packaging',
    state: 'todo',
    deliverables: [
      'Paquet .deb + image Docker + bundle hors-ligne',
      'Sauvegarde / restauration atomique',
      'Logs d\'audit conformité (SIEM JSONL)',
      'Patterns haute disponibilité (Litestream + rsync)',
      'Documentation projet OSS complète (CONTRIBUTING / SECURITY / Code of Conduct)',
    ],
  },
];

const stateLabel: Record<Phase['state'], string> = {
  done: '✓ shipped',
  next: 'in flight',
  todo: 'planned',
};
---
<section id="roadmap" class="roadmap section-pad section-gap" aria-labelledby="roadmap-title">
  <div class="roadmap-inner">
    <div class="eyebrow">VI · Status & Roadmap</div>
    <h2 id="roadmap-title" class="roadmap-h2">Five phases shipped. Three milestones ahead.</h2>
    <p class="roadmap-meta">
      <code>v0.1.0-alpha.9-patch.1</code> · 698 tests · 27 crates · Rust 2021 edition · MSRV 1.75 ·
      service mode shipped 2026-05-07 · vault_downgrade &amp; full search hardening shipped 2026-05-09.
    </p>

    <div class="phases-list" role="list">
      {phases.map((p) => (
        <div class={`phase-row state-${p.state}`} role="listitem">
          <div class="phase-num" aria-hidden="true">
            {p.num}
          </div>

          <div class="phase-body">
            <div class="phase-header">
              <div>
                <div class="phase-title">{p.title}</div>
                <div class="phase-subtitle">{p.subtitle}</div>
              </div>
              {p.tag && (
                <span class="phase-tag">{p.tag}</span>
              )}
            </div>

            <ul class="phase-deliverables" role="list">
              {p.deliverables.map((d) => (
                <li>{d}</li>
              ))}
            </ul>
          </div>

          <div class={`phase-status status-${p.state}`} aria-label={`Status: ${stateLabel[p.state]}`}>
            {stateLabel[p.state]}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .roadmap {
    background: var(--paper);
  }

  .roadmap-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .roadmap-h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 3.5vw, 2.875rem);
    font-weight: 500;
    margin-top: 1rem;
  }

  .roadmap-meta {
    margin-top: 1rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--muted);
  }

  /* Phase rows */
  .phases-list {
    margin-top: 3.5rem;
    display: flex;
    flex-direction: column;
  }

  .phase-row {
    display: grid;
    grid-template-columns: 7rem 1fr 8rem;
    gap: 2rem;
    padding: 1.75rem 0;
    border-top: 1px solid var(--rule);
    align-items: start;
  }

  /* Large italic phase number */
  .phase-num {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 0.9;
    color: var(--muted);
  }

  .state-done .phase-num {
    color: var(--accent);
  }

  .phase-title {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.1;
  }

  .phase-subtitle {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
    letter-spacing: 0.08em;
    margin-top: 0.375rem;
  }

  .phase-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .phase-tag {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 0.2em 0.6em;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .phase-deliverables {
    list-style: none;
    margin-top: 0.875rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .phase-deliverables li {
    font-size: 0.9375rem;
    color: var(--ink-soft);
    line-height: 1.5;
  }

  .phase-deliverables li::before {
    content: '— ';
    color: var(--rule);
  }

  /* Status badge */
  .phase-status {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-align: right;
    color: var(--muted);
    padding-top: 0.5rem;
  }

  .status-done {
    color: var(--accent);
  }

  @media (max-width: 768px) {
    .phase-row {
      grid-template-columns: 4rem 1fr;
      grid-template-rows: auto auto;
    }

    .phase-status {
      grid-column: 2;
      text-align: left;
      padding-top: 0.5rem;
    }
  }
</style>
