---
import { versionPhases } from '../data/roadmap';
import type { Milestone } from '../content/config';

const milestoneIcon: Record<Milestone['status'], string> = {
  done: '✓',
  'in-progress': '⚡',
  next: '·',
  planned: '·',
};

const isExpandedByDefault = (v: string) =>
  v === 'v0.2.0' || v === 'v0.3.0' || v === 'v0.4.0' || v === 'v0.5.2' || v === 'v1.0.0' || v === 'v2.0.0';

const slugifyVersion = (v: string) => v.replace(/\./g, '-'); // v0.1.0 → v0-1-0

// 2-chapter markers: inject narrative dividers before v0.4.0 and v0.7.0
const CHAPTER_MEMORY_START = 'v0.4.0';     // Memory layer begins
const CHAPTER_AGENTS_START = 'v0.7.0';    // Context Assembly + Agent Runtime begins
---

<section id="roadmap" class="roadmap section-pad section-gap" aria-labelledby="roadmap-title">
  <div class="roadmap-inner">
    <div class="eyebrow">VI · Status &amp; Roadmap</div>
    <h2 id="roadmap-title" class="roadmap-h2">Roadmap — ten versions, four milestones</h2>
    <p class="roadmap-meta">
      <code>v0.5.2</code> · 31 crates workspace · Apache-2.0 · Rust 2024 · MSRV 1.88+ ·
      <a href="https://github.com/gradatum/gradatum" target="_blank" rel="noopener noreferrer" class="roadmap-meta-link">GitHub</a> ·
      <a href="https://crates.io/crates/gradatum" target="_blank" rel="noopener noreferrer" class="roadmap-meta-link">crates.io</a>
      <span class="roadmap-meta-note">(names reserved — full library at v1.0)</span>
    </p>

    <div class="version-phases" role="list">
      {versionPhases.map((phase) => {
        const slug = slugifyVersion(phase.version);
        const expanded = isExpandedByDefault(phase.version);
        return (
          <>
            {phase.version === CHAPTER_MEMORY_START && (
              <div class="chapter-divider" id="chapter-memory" aria-label="Chapter: Memory layer">
                <span class="chapter-eyebrow eyebrow">Chapter I</span>
                <h3 class="chapter-title">Memory layer</h3>
                <p class="chapter-desc">
                  v0.4.0 → v0.5.1 — Completes the durable memory store: structured ingest,
                  note history, temporal decay, distillation, MCP-native querying, multi-user
                  isolation, and OAuth-based remote access. The queryable, sovereign memory
                  store that other systems — and eventually gradatum itself — will build on.
                </p>
              </div>
            )}
            {phase.version === CHAPTER_AGENTS_START && (
              <div class="chapter-divider" id="chapter-agents" aria-label="Chapter: Context Assembly + Agent Runtime">
                <span class="chapter-eyebrow eyebrow">Chapter II</span>
                <h3 class="chapter-title">Context Assembly + Agent Runtime</h3>
                <p class="chapter-desc">
                  v0.7.0+ — The layer that consumes the memory store coherently across sessions:
                  context assembly, sliding-window memory, proactive recall, skill selection,
                  and a declarative user profile. gradatum stops treating queries as stateless
                  and starts reasoning over accumulated knowledge.
                </p>
              </div>
            )}
            <details
              id={`v-${slug}`}
              class={`version-phase state-${phase.status}${phase.grade ? ` grade-${phase.grade.toLowerCase()}` : ''}`}
              role="listitem"
              open={expanded}
            >
              <summary class="version-summary">
                <div class="version-summary-inner">
                  <span class="version-eyebrow eyebrow">{phase.version} · {phase.theme.toLowerCase()}</span>
                  <h3 class="version-title">
                    {phase.grade && (
                      <span
                        class={`grade-badge grade-${phase.grade.toLowerCase()}`}
                        aria-label={`${phase.grade} grade milestone`}
                      >
                        {phase.grade.toUpperCase()}
                      </span>
                    )}
                    {phase.theme}
                  </h3>
                  <span
                    class={`phase-state-badge badge-${phase.status}`}
                    aria-label={`Status: ${phase.status === 'in-progress' ? 'in progress' : phase.status === 'done' ? 'shipped' : 'planned'}`}
                  >
                    {phase.status === 'in-progress' ? '⚡ IN PROGRESS' : phase.status === 'done' ? '✓ SHIPPED' : 'planned'}
                  </span>
                </div>
              </summary>

              <div class="version-content">
                <p class="version-description">{phase.description}</p>

                {phase.showFeaturesLink && (
                  <a href="/features" class="features-link eyebrow">
                    explore shipped features →
                  </a>
                )}

                {phase.milestones && (
                  <ol class="milestones-list" aria-label={`Milestones ${phase.version}`}>
                    {phase.milestones.map((m) => (
                      <li class={`milestone milestone-${m.status}`}>
                        <span class="milestone-icon" aria-hidden="true">{milestoneIcon[m.status]}</span>
                        <span class="milestone-title">{m.title}</span>
                        <span class="milestone-version">{m.version}</span>
                        {m.date && (
                          <span class="milestone-date" aria-label={`date: ${m.date}`}>{m.date}</span>
                        )}
                      </li>
                    ))}
                  </ol>
                )}

                {phase.scopeTeaserItems && phase.scopeTeaserItems.length > 0 && (
                  <p class="scope-teaser">
                    {phase.scopeTeaserItems.join(' · ')}
                  </p>
                )}
              </div>
            </details>
          </>
        );
      })}
    </div>
  </div>
</section>

<script is:inline>
  /* Auto-open <details> targeted by location.hash (deep links #v-0-5-0) */
  (function() {
    function openTargeted() {
      var hash = window.location.hash;
      if (!hash || hash.indexOf('#v-') !== 0) return;
      var target = document.querySelector(hash);
      if (target && target.tagName === 'DETAILS') {
        target.open = true;
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }
    openTargeted();
    window.addEventListener('hashchange', openTargeted);
  })();
</script>

<style>
  .roadmap {
    background: var(--paper);
  }

  .roadmap-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .roadmap-h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 3.5vw, 2.875rem);
    font-weight: 500;
    margin-top: 1rem;
  }

  .roadmap-meta {
    margin-top: 1rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--muted);
  }

  .roadmap-meta-link {
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .roadmap-meta-link:hover {
    color: var(--accent);
  }

  .roadmap-meta-note {
    color: var(--muted);
    font-style: italic;
  }

  /* ── Chapter dividers (2-chapter structure) ──────────── */

  .chapter-divider {
    margin-top: 4rem;
    padding: 2rem 0 1.5rem;
    border-top: 2px solid var(--accent);
  }

  .chapter-eyebrow {
    color: var(--accent);
    letter-spacing: 0.2em;
  }

  .chapter-title {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 500;
    font-style: italic;
    color: var(--ink);
    margin: 0.5rem 0 0.875rem;
  }

  .chapter-desc {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--ink-soft);
    max-width: 64ch;
    margin: 0;
  }

  /* ── Version phases ───────────────────────────────────── */

  .version-phases {
    margin-top: 3.5rem;
    display: flex;
    flex-direction: column;
  }

  .version-phase {
    padding: 2.5rem 0;
    border-top: 1px solid var(--rule);
    scroll-margin-top: 5rem;
  }

  .version-phase:last-child {
    border-bottom: 1px solid var(--rule);
  }

  .version-phase.state-planned {
    opacity: 0.72;
  }

  /* ── Summary / toggle ────────────────────────────────── */

  .version-summary {
    cursor: pointer;
    list-style: none;
    min-height: 44px; /* touch target */
  }

  .version-summary::-webkit-details-marker {
    display: none;
  }

  .version-summary::marker {
    content: '';
  }

  .version-summary:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .version-summary-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    row-gap: 0.5rem;
    column-gap: 1.5rem;
    align-items: baseline;
  }

  .version-eyebrow {
    grid-column: 1 / -1;
    margin-bottom: 0.25rem;
  }

  .version-title {
    grid-column: 1;
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 500;
    line-height: 1.05;
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  /* ── Grade badges ─────────────────────────────────────── */

  .grade-badge {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    line-height: 1;
    flex-shrink: 0;
  }

  .grade-badge.grade-bronze {
    color: var(--grade-bronze);
    background: color-mix(in srgb, var(--grade-bronze) 14%, transparent);
  }

  .grade-badge.grade-silver {
    color: var(--grade-silver);
    background: color-mix(in srgb, var(--grade-silver) 14%, transparent);
  }

  .grade-badge.grade-gold {
    color: var(--grade-gold);
    background: color-mix(in srgb, var(--grade-gold) 14%, transparent);
  }

  .grade-badge.grade-platinum {
    color: var(--grade-platinum);
    background: color-mix(in srgb, var(--grade-platinum) 14%, transparent);
  }

  /* ── Phase state badge ────────────────────────────────── */

  .phase-state-badge {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    align-self: center;
    grid-column: 2;
    grid-row: 2;
  }

  .badge-in-progress {
    color: var(--accent);
    font-weight: 700;
  }

  .badge-planned {
    color: var(--muted);
  }

  .badge-done {
    color: var(--muted);
  }

  .version-phase.state-done {
    opacity: 0.82;
  }

  /* ── Version content ──────────────────────────────────── */

  .version-content {
    margin-top: 1.5rem;
  }

  .version-description {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--ink-soft);
    margin: 0;
    max-width: 68ch;
  }

  /* ── Features link ────────────────────────────────────── */

  .features-link {
    display: inline-block;
    margin-top: 0.875rem;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: 0.14em;
  }

  .features-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── Milestones list ──────────────────────────────────── */

  .milestones-list {
    list-style: none;
    margin-top: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-left: 1px solid var(--rule);
    padding-left: 1.5rem;
  }

  .milestone {
    display: grid;
    grid-template-columns: 1.25rem 1fr auto auto;
    align-items: baseline;
    gap: 0.5rem 0.875rem;
    padding: 0.45rem 0;
    border-bottom: 1px solid color-mix(in srgb, var(--rule) 40%, transparent);
  }

  .milestone:last-child {
    border-bottom: none;
  }

  /* Icon column */
  .milestone-icon {
    font-size: 0.875rem;
    text-align: center;
    flex-shrink: 0;
  }

  .milestone-done .milestone-icon    { color: var(--accent); }
  .milestone-in-progress .milestone-icon { color: var(--accent); }
  .milestone-next .milestone-icon    { color: var(--muted); }
  .milestone-planned .milestone-icon { color: var(--rule); }

  /* Title */
  .milestone-title {
    font-size: 0.9375rem;
    line-height: 1.45;
  }

  .milestone-done .milestone-title        { color: var(--ink-soft); }
  .milestone-in-progress .milestone-title { color: var(--ink); font-weight: 500; }
  .milestone-next .milestone-title        { color: var(--ink-soft); }
  .milestone-planned .milestone-title     { color: var(--muted); font-style: italic; }

  /* Version chip */
  .milestone-version {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    color: var(--muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .milestone-in-progress .milestone-version {
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 40%, transparent);
    padding: 0.1em 0.45em;
  }

  /* Date */
  .milestone-date {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.08em;
    color: var(--rule);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Scope teaser ─────────────────────────────────────── */

  .scope-teaser {
    margin-top: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.5;
  }

  /* ── Responsive ───────────────────────────────────────── */

  @media (max-width: 768px) {
    .version-summary-inner {
      grid-template-columns: 1fr;
    }

    .phase-state-badge {
      grid-column: 1;
      grid-row: auto;
    }

    .milestone {
      grid-template-columns: 1.25rem 1fr;
      grid-template-rows: auto auto;
      row-gap: 0.2rem;
    }

    .milestone-version {
      grid-column: 2;
      grid-row: 2;
    }

    .milestone-date {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .milestones-list {
      padding-left: 1rem;
    }

    .version-title {
      font-size: 1.5rem;
    }
  }
</style>
