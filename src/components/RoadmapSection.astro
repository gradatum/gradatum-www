---
// Roadmap — numbering convention (validated 2026-05-28) :
//   Numéro de phase = 2 chiffres = v{X.Y}
//   Toutes les versions v{X.Y}.<patch>-alpha.<N> / -bumps.<N> / -patch.<N>
//   appartiennent à la même phase X.Y.
//
// Mapping historique → milestones Phase 0.1 :
//   Phase 1, 2.0, 2.1, 2.2, 2.2.1, 2.3, 2.4, 2.5, 2.6, 2.x
//   → milestones chronologiques sous Phase 0.1 (v0.1.x alpha series)

interface Milestone {
  status: 'done' | 'in-progress' | 'next' | 'planned';
  title: string;
  version: string;
  date?: string;
}

interface MacroPhase {
  num: string;
  versionPrefix: string;
  versionSuffix: string;
  state: 'in-progress' | 'planned';
  description: string;
  milestones?: Milestone[];
  scopeTeaser?: string;
}

const macroPhases: MacroPhase[] = [
  {
    num: '0.1',
    versionPrefix: 'v0.1.x',
    versionSuffix: 'alpha series',
    state: 'in-progress',
    description: 'Embedded memory backbone for AI agents (alpha series)',
    milestones: [
      {
        status: 'done',
        title: 'Functional core',
        version: 'v0.1.0-alpha.0→5',
        date: '2026-04',
      },
      {
        status: 'done',
        title: 'Service mode (HTTP + MCP)',
        version: 'v0.1.0-alpha.5',
        date: '2026-05-07',
      },
      {
        status: 'done',
        title: 'Hardening + search foundations',
        version: 'v0.1.0-alpha.7→10',
        date: '2026-05',
      },
      {
        status: 'done',
        title: 'Supply chain bumps',
        version: 'v0.1.0-alpha.10-bumps.1',
        date: '2026-05',
      },
      {
        status: 'done',
        title: 'Search quality (RRF + reranker)',
        version: 'v0.1.0-alpha.11→13',
        date: '2026-05',
      },
      {
        status: 'done',
        title: 'Double run + decommission predecessor',
        version: 'memory backend migrated',
        date: '2026-05-25',
      },
      {
        status: 'done',
        title: 'Security hardening — JWT validate_nbf',
        version: 'v0.1.0-alpha.14',
        date: '2026-05-28',
      },
      {
        status: 'done',
        title: 'Gradatum Skills (reminder + vault-search)',
        version: 'gradatum-skills v0.1.0',
        date: '2026-05-25',
      },
      {
        status: 'done',
        title: 'Polish — title resolution, batched lookups, parallel wikilinks',
        version: 'v0.1.0-alpha.15',
        date: '2026-05-28',
      },
      {
        status: 'next',
        title: 'Stabilisation — alpha series wrap-up, OSS feedback integration',
        version: 'v0.1.x closing',
      },
    ],
  },
  {
    num: '0.2',
    versionPrefix: 'v0.2.x',
    versionSuffix: 'beta candidate',
    state: 'planned',
    description: 'Stabilisation + feedback OSS',
    scopeTeaser: 'TBD scope — defined after alpha series completion',
  },
  {
    num: '1.0',
    versionPrefix: 'v1.0.x',
    versionSuffix: 'OSS public release',
    state: 'planned',
    description: 'Production-ready packaging',
    scopeTeaser: '.deb package, Docker image, offline bundle, audit logs SIEM-ingestable, high-availability blueprints, full OSS onboarding (CONTRIBUTING, SECURITY, Code of Conduct)',
  },
];

const milestoneIcon: Record<Milestone['status'], string> = {
  done: '✓',
  'in-progress': '⚡',
  next: '·',
  planned: '·',
};
---

<section id="roadmap" class="roadmap section-pad section-gap" aria-labelledby="roadmap-title">
  <div class="roadmap-inner">
    <div class="eyebrow">VI · Status & Roadmap</div>
    <h2 id="roadmap-title" class="roadmap-h2">Roadmap — phases shipped and in flight</h2>
    <p class="roadmap-meta">
      <code>v0.1.0-alpha.15</code> · 826 tests · 26 crates · Rust 2021 · MSRV 1.85
    </p>

    <div class="macro-phases" role="list">
      {macroPhases.map((phase) => (
        <article class={`macro-phase state-${phase.state}`} role="listitem">
          <header class="macro-header">
            <div class="version-prefix eyebrow">
              {phase.versionPrefix} — {phase.versionSuffix}
            </div>
            <div class="macro-title-row">
              <span class="phase-num" aria-hidden="true">Phase {phase.num}</span>
              <span
                class={`phase-state-badge badge-${phase.state}`}
                aria-label={`Status: ${phase.state === 'in-progress' ? 'in progress' : 'planned'}`}
              >
                {phase.state === 'in-progress' ? '⚡ IN PROGRESS' : 'planned'}
              </span>
            </div>
            <p class="macro-description">{phase.description}</p>
            {phase.num === '0.1' && (
              <a href="/features" class="features-link eyebrow">
                explore shipped features →
              </a>
            )}
          </header>

          {phase.milestones && (
            <ol class="milestones-list" aria-label={`Milestones Phase ${phase.num}`}>
              {phase.milestones.map((m) => (
                <li class={`milestone milestone-${m.status}`}>
                  <span class="milestone-icon" aria-hidden="true">
                    {milestoneIcon[m.status]}
                  </span>
                  <span class="milestone-title">{m.title}</span>
                  <span class="milestone-version">{m.version}</span>
                  {m.date && (
                    <span class="milestone-date" aria-label={`date: ${m.date}`}>
                      {m.date}
                    </span>
                  )}
                </li>
              ))}
            </ol>
          )}

          {phase.scopeTeaser && (
            <p class="scope-teaser">{phase.scopeTeaser}</p>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .roadmap {
    background: var(--paper);
  }

  .roadmap-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .roadmap-h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 3.5vw, 2.875rem);
    font-weight: 500;
    margin-top: 1rem;
  }

  .roadmap-meta {
    margin-top: 1rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--muted);
  }

  /* ── Macro phases ─────────────────────────────────────── */

  .macro-phases {
    margin-top: 3.5rem;
    display: flex;
    flex-direction: column;
  }

  .macro-phase {
    padding: 2.5rem 0;
    border-top: 1px solid var(--rule);
  }

  .macro-phase:last-child {
    border-bottom: 1px solid var(--rule);
  }

  /* Planned phases: slightly muted but NOT faded */
  .macro-phase.state-planned {
    opacity: 0.72;
  }

  /* ── Macro header ─────────────────────────────────────── */

  .macro-header {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto auto;
    row-gap: 0.5rem;
    column-gap: 1.5rem;
    align-items: start;
  }

  /* eyebrow spans full width */
  .macro-header .version-prefix {
    grid-column: 1 / -1;
    margin-bottom: 0.25rem;
  }

  .macro-title-row {
    grid-column: 1;
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  /* Phase num — grande italic, sérigraphique */
  .phase-num {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 500;
    line-height: 0.95;
    color: var(--accent);
  }

  .state-planned .phase-num {
    color: var(--muted);
  }

  /* Badge état */
  .phase-state-badge {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    align-self: center;
  }

  .badge-in-progress {
    color: var(--accent);
    font-weight: 700;
  }

  .badge-planned {
    color: var(--muted);
  }

  /* Description */
  .macro-description {
    grid-column: 1 / -1;
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-style: italic;
    color: var(--ink-soft);
    line-height: 1.4;
  }

  /* ── Milestones list ──────────────────────────────────── */

  .milestones-list {
    list-style: none;
    margin-top: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-left: 1px solid var(--rule);
    padding-left: 1.5rem;
  }

  .milestone {
    display: grid;
    grid-template-columns: 1.25rem 1fr auto auto;
    align-items: baseline;
    gap: 0.5rem 0.875rem;
    padding: 0.45rem 0;
    border-bottom: 1px solid color-mix(in srgb, var(--rule) 40%, transparent);
  }

  .milestone:last-child {
    border-bottom: none;
  }

  /* Icon column */
  .milestone-icon {
    font-size: 0.875rem;
    text-align: center;
    flex-shrink: 0;
  }

  .milestone-done .milestone-icon {
    color: var(--accent);
  }

  .milestone-in-progress .milestone-icon {
    color: var(--accent);
  }

  .milestone-next .milestone-icon {
    color: var(--muted);
  }

  .milestone-planned .milestone-icon {
    color: var(--rule);
  }

  /* Title */
  .milestone-title {
    font-size: 0.9375rem;
    line-height: 1.45;
  }

  .milestone-done .milestone-title {
    color: var(--ink-soft);
  }

  .milestone-in-progress .milestone-title {
    color: var(--ink);
    font-weight: 500;
  }

  .milestone-next .milestone-title {
    color: var(--ink-soft);
  }

  .milestone-planned .milestone-title {
    color: var(--muted);
    font-style: italic;
  }

  /* Version chip */
  .milestone-version {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    color: var(--muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .milestone-in-progress .milestone-version {
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 40%, transparent);
    padding: 0.1em 0.45em;
  }

  /* Date */
  .milestone-date {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.08em;
    color: var(--rule);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ── Features link (Phase 0.1 only) ──────────────────── */

  .features-link {
    display: inline-block;
    margin-top: 0.75rem;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: 0.14em;
  }

  .features-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── Scope teaser (planned phases) ───────────────────── */

  .scope-teaser {
    margin-top: 1.25rem;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.0625rem;
    color: var(--muted);
    line-height: 1.55;
    max-width: 56ch;
  }

  /* ── Responsive ───────────────────────────────────────── */

  @media (max-width: 768px) {
    .macro-header {
      grid-template-columns: 1fr;
    }

    .macro-header .version-prefix {
      grid-column: 1;
    }

    .phase-state-badge {
      /* inline after phase-num on mobile */
    }

    .milestone {
      grid-template-columns: 1.25rem 1fr;
      grid-template-rows: auto auto;
      row-gap: 0.2rem;
    }

    .milestone-version {
      grid-column: 2;
      grid-row: 2;
    }

    .milestone-date {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .milestones-list {
      padding-left: 1rem;
    }

    .phase-num {
      font-size: 2rem;
    }
  }
</style>
