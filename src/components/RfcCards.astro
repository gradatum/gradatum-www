---
// RFC cards — RFC-0001 / RFC-0002 / RFC-0003
// Source: ../gradatum/docs/RFC/RFC-*.md (status, summary extracted manually)
const GITHUB_URL = 'https://github.com/gradatum/gradatum';

interface RFC {
  num: string;
  title: string;
  status: 'accepted' | 'draft' | 'superseded';
  summary: string;
  url: string;
}

const rfcs: RFC[] = [
  {
    num: '0001',
    title: 'Versioning gradatum-core',
    status: 'accepted',
    summary: 'Trait stability tiers and versioning policy for gradatum-core. Defines stable/unstable/internal tiers and SemVer rules per tier.',
    url: `${GITHUB_URL}/blob/main/docs/RFC/RFC-0001-versioning-gradatum-core.md`,
  },
  {
    num: '0002',
    title: 'Cross-platform support',
    status: 'accepted',
    summary: 'B-light tiered model: Linux x86_64 primary (full CI + runtime), Windows x86_64 secondary (cross-compile mingw-w64, manual pre-release). 13 portability rules R1–R13.',
    url: `${GITHUB_URL}/blob/main/docs/RFC/RFC-0002-cross-platform-support.md`,
  },
  {
    num: '0003',
    title: 'HTTP API surface and MCP integration',
    status: 'accepted',
    summary: 'Single-port :19090 path-prefix routing (/api/v1 /mcp /sse /health /admin). gradatum-mcp-stub as stdio bridge for Claude Code, Claude Desktop, ZeroClaw.',
    url: `${GITHUB_URL}/blob/main/docs/RFC/RFC-0003-http-api-surface-and-mcp-integration.md`,
  },
];
---
<section class="rfcs section-pad section-gap" aria-labelledby="rfcs-title">
  <div class="rfcs-inner">
    <div class="eyebrow">VII · RFCs</div>
    <h2 id="rfcs-title" class="rfcs-h2">Design decisions, written down.</h2>
    <p class="rfcs-desc">
      All major architectural choices are captured as RFCs. Three accepted so far.
    </p>

    <ul class="rfcs-grid" role="list">
      {rfcs.map((rfc) => (
        <li class="rfc-card">
          <a href={rfc.url} target="_blank" rel="noopener noreferrer" class="rfc-link" aria-label={`RFC-${rfc.num}: ${rfc.title}`}>
            <div class="rfc-header">
              <span class="rfc-num eyebrow">RFC-{rfc.num}</span>
              <span class={`rfc-status status-${rfc.status}`}>{rfc.status}</span>
            </div>
            <div class="rfc-title">{rfc.title}</div>
            <p class="rfc-summary">{rfc.summary}</p>
            <span class="rfc-read">Read →</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .rfcs {
    background: var(--paper);
  }

  .rfcs-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .rfcs-h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 3.5vw, 2.875rem);
    font-weight: 500;
    margin-top: 1rem;
  }

  .rfcs-desc {
    margin-top: 1rem;
    font-size: 1.0625rem;
    color: var(--ink-soft);
  }

  .rfcs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 2.5rem;
    list-style: none;
  }

  .rfc-card {
    border: 1px solid var(--rule);
    background: var(--bg);
    transition: border-color 0.15s ease;
  }

  .rfc-card:hover {
    border-color: var(--accent);
  }

  .rfc-link {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    text-decoration: none;
    color: var(--ink);
    height: 100%;
  }

  .rfc-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .rfc-num {
    letter-spacing: 0.14em;
  }

  .rfc-status {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.2em 0.5em;
  }

  .status-accepted {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }

  .status-draft {
    color: var(--muted);
    background: color-mix(in srgb, var(--muted) 12%, transparent);
  }

  .rfc-title {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.2;
  }

  .rfc-summary {
    font-size: 0.9375rem;
    color: var(--ink-soft);
    line-height: 1.55;
    flex: 1;
    margin: 0;
  }

  .rfc-read {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
    letter-spacing: 0.06em;
    margin-top: 0.5rem;
  }

  @media (max-width: 768px) {
    .rfcs-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
