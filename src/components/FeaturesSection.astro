---
import { featureGroups } from '../data/features';
import type { FeatureGroup } from '../content/config';

const GRADE_LABELS: Record<FeatureGroup['grade'], string> = {
  Bronze: 'I',
  Silver: 'II',
  Gold: 'III',
  Platinum: 'IV',
};
---

<section class="features section-pad section-gap" aria-labelledby="features-title">
  <div class="features-inner">
    <div class="eyebrow">Features — Gradatum Vault</div>
    <h1 id="features-title" class="features-h1">
      What ships in each release
    </h1>
    <p class="features-lead">
      Each feature below ships with a stable reference identifier (F-XX) used across
      the documentation and changelog. Anchor links are permanent.
    </p>
    <p class="features-grade-note">
      Grades mark maturity tiers; versions mark delivery. A feature may ship in an earlier version than its grade tier.
    </p>

    {featureGroups.map((group) => (
      <div class="feature-group">
        <header class="group-header">
          <div class="eyebrow group-eyebrow">
            {GRADE_LABELS[group.grade]} · {group.versionPrefix}
          </div>
          <h2 class="group-grade">{group.grade}</h2>
          <p class="group-description">{group.description}</p>
        </header>

        <div class="feature-list" role="list">
          {group.features.map((feature) => (
            <article
              id={feature.id}
              class="feature-item"
              data-grade={group.grade.toLowerCase()}
              data-status={feature.status}
              role="listitem"
            >
              <div class="feature-eyebrow-row">
                <span class="eyebrow feature-ref">{feature.refLabel}</span>
                <span class={`feature-status status-${feature.status}`}>
                  {feature.status}
                </span>
                <span class="eyebrow feature-version">{feature.version}</span>
                <a href={`#${feature.id}`} class="feature-anchor" aria-label={`Permalink to ${feature.name}`}>
                  #
                </a>
              </div>

              <h3 class="feature-name">{feature.name}</h3>

              <p class="feature-positioning">{feature.positioning}</p>

              <div class="feature-how">
                {feature.howItWorks.map((step) => (
                  <p class="feature-how-step">{step}</p>
                ))}
              </div>

              <p class="feature-who">
                <span class="who-label">For:</span>
                {feature.whoItsFor}
              </p>
            </article>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .features {
    background: var(--paper);
  }

  .features-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .features-h1 {
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 3.5vw, 2.875rem);
    font-weight: 500;
    margin-top: 1rem;
    letter-spacing: -0.01em;
  }

  .features-lead {
    margin-top: 1rem;
    font-size: 1.0625rem;
    color: var(--ink-soft);
    max-width: 64ch;
    line-height: 1.6;
  }

  /* ── Feature group ──────────────────────────────────────── */

  .feature-group {
    margin-top: 4rem;
  }

  .group-header {
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--rule);
  }

  .group-eyebrow {
    margin-bottom: 0.5rem;
  }

  .group-grade {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 500;
    line-height: 0.95;
    color: var(--accent);
    letter-spacing: -0.01em;
  }

  .group-description {
    margin-top: 0.875rem;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.1875rem;
    color: var(--ink-soft);
    line-height: 1.45;
    max-width: 68ch;
  }

  /* ── Feature list ───────────────────────────────────────── */

  .feature-list {
    display: flex;
    flex-direction: column;
  }

  /* ── Feature item ───────────────────────────────────────── */

  .feature-item {
    padding: 2.5rem 0;
    border-bottom: 1px solid color-mix(in srgb, var(--rule) 60%, transparent);
    /* Anchor offset under sticky nav */
    scroll-margin-top: 5rem;
  }

  .feature-item:first-child {
    padding-top: 2.25rem;
  }

  .feature-item:last-child {
    border-bottom: none;
  }

  /* ── Eyebrow row ────────────────────────────────────────── */

  .feature-eyebrow-row {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    flex-wrap: wrap;
    margin-bottom: 0.875rem;
  }

  .feature-ref {
    letter-spacing: 0.18em;
  }

  /* Status badges */
  .feature-status {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.2em 0.55em;
  }

  .status-released {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }

  .status-planned {
    /* P1-3: ink-soft for contrast, not muted */
    color: var(--ink-soft);
    background: color-mix(in srgb, var(--ink-soft) 10%, transparent);
  }

  .status-roadmap {
    color: var(--ink-soft);
    background: color-mix(in srgb, var(--ink-soft) 8%, transparent);
  }

  .feature-version {
    color: var(--muted);
    letter-spacing: 0.1em;
  }

  .feature-anchor {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--rule);
    text-decoration: none;
    letter-spacing: 0;
    transition: color 0.15s ease;
    padding: 0.1em 0.3em;
    margin-left: auto;
  }

  .feature-anchor:hover {
    color: var(--accent);
  }

  .feature-item:target .feature-anchor {
    color: var(--accent);
  }

  /* ── Feature name ───────────────────────────────────────── */

  .feature-name {
    font-family: var(--font-serif);
    font-size: clamp(1.375rem, 2.5vw, 1.875rem);
    font-weight: 500;
    color: var(--ink);
    line-height: 1.15;
    letter-spacing: -0.01em;
    max-width: 72ch;
    margin-bottom: 0.875rem;
  }

  /* ── Positioning ────────────────────────────────────────── */

  .feature-positioning {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.125rem;
    color: var(--ink-soft);
    line-height: 1.5;
    max-width: 68ch;
    margin-bottom: 1.25rem;
  }

  /* ── How it works ───────────────────────────────────────── */

  .feature-how {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    border-left: 2px solid color-mix(in srgb, var(--rule) 80%, transparent);
    padding-left: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .feature-how-step {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--ink-soft);
    max-width: 72ch;
  }

  /* ── Who it's for ───────────────────────────────────────── */

  .feature-who {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--muted);
    line-height: 1.6;
    max-width: 64ch;
  }

  .who-label {
    font-weight: 500;
    color: var(--ink-soft);
    margin-right: 0.375rem;
    letter-spacing: 0.04em;
  }

  /* ── Target highlight ───────────────────────────────────── */

  .feature-item:target {
    background: color-mix(in srgb, var(--accent) 4%, transparent);
    padding-left: 1.25rem;
    margin-left: -1.25rem;
    padding-right: 1.25rem;
    margin-right: -1.25rem;
    border-radius: 2px;
  }

  /* ── Responsive ─────────────────────────────────────────── */

  @media (max-width: 768px) {
    .feature-item {
      padding: 2rem 0;
    }

    .feature-eyebrow-row {
      gap: 0.625rem;
    }

    .feature-anchor {
      margin-left: 0;
    }
  }

  @media (max-width: 480px) {
    .feature-how {
      padding-left: 0.875rem;
    }

    .feature-item:target {
      padding-left: 0.75rem;
      margin-left: -0.75rem;
      padding-right: 0.75rem;
      margin-right: -0.75rem;
    }
  }
</style>
