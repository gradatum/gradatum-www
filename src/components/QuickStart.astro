<section id="install" class="qs section-pad section-gap" aria-labelledby="qs-title">
  <div class="qs-inner">
    <div class="eyebrow">VIII · Quick start</div>
    <h2 id="qs-title" class="qs-h2">
      Pre-built binaries, crates.io, or build from source.
    </h2>

    <div class="qs-teaser-cta">
      <a href="/install" class="cta-link eyebrow">View all install modes (7 profiles)</a>
      <a href="https://github.com/gradatum/gradatum" target="_blank" rel="noopener noreferrer" class="cta-link eyebrow">Source on GitHub →</a>
      <a href="/use-cases" class="cta-link eyebrow">See use cases (Without / With)</a>
    </div>

    <div class="qs-blocks">
      <!-- Block 1: Clone & build -->
      <div class="qs-block">
        <div class="eyebrow block-label">Clone &amp; build (v0.4.1 · API not stable before v1.0)</div>
        <pre class="qs-pre"><code><span class="c"># build from source</span>
git clone https://github.com/gradatum/gradatum
cd gradatum && cargo build --release --workspace

<span class="c"># initialize a vault with the hierarchical preset</span>
gradatum-admin init --preset hierarchical \
  --root /var/lib/gradatum

<span class="c"># start the server</span>
systemctl --user start gradatum-server</code></pre>
      </div>

      <!-- Block 2: Write & search via HTTP API -->
      <div class="qs-block">
        <div class="eyebrow block-label">Write &amp; search (REST API)</div>
        <pre class="qs-pre" set:html={`<code><span class="c"># write a note (vault_write)</span>
curl -X POST http://localhost:19090/api/v1/vault_write \\
  -H "Authorization: Bearer &#36;GRADATUM_BEARER" \\
  -H "Content-Type: application/json" \\
  -d '&#123;"locus":"projecta/backend","section":"decisions","body":"Use ULID for stable note identity"&#125;'

<span class="c"># search across loci</span>
curl http://localhost:19090/api/v1/vault_search \\
  -H "Authorization: Bearer &#36;GRADATUM_BEARER" \\
  -d '&#123;"query":"ULID identity","locus":"projecta/*"&#125;'

<span class="c"># list vaults</span>
gradatum-admin vault list</code>`}></pre>
      </div>

      <!-- Block 3: MCP stub -->
      <div class="qs-block">
        <div class="eyebrow block-label">MCP integration (MCP stub)</div>
        <pre class="qs-pre" set:html={`<code><span class="c"># gradatum.toml — MCP stub for Claude Code</span>
[[mcpServers]]
name    = &quot;gradatum&quot;
command = &quot;gradatum-mcp-stub&quot;
args    = [&quot;--server&quot;, &quot;http://localhost:19090&quot;]
env     = &#123; GRADATUM_BEARER = &quot;your-bearer-token&quot; &#125;

<span class="c"># Or via HTTP directly (API)</span>
curl http://localhost:19090/health
curl http://localhost:19090/api/v1/vault_search \\
  -d '&#123;"query":"ULID","locus":"projecta/*"&#125;'</code>`}></pre>
      </div>
    </div>

    <p class="qs-note">
      v0.4.1 — pre-built binaries (server / llm / mcp) on
      <a href="https://github.com/gradatum/gradatum/releases" target="_blank" rel="noopener noreferrer" class="qs-note-link">GitHub Releases</a>,
      source on <a href="https://github.com/gradatum/gradatum" target="_blank" rel="noopener noreferrer" class="qs-note-link">GitHub</a>,
      crates on <a href="https://crates.io/crates/gradatum" target="_blank" rel="noopener noreferrer" class="qs-note-link">crates.io</a>.
      API not stable before v1.0. See the
      <a href="/install" class="qs-note-link">Install page</a> for all deployment profiles.
    </p>
  </div>
</section>

<style>
