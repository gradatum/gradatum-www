---
const YEAR = new Date().getFullYear();

const stackLinks = [
  { label: 'Apache OpenDAL', href: 'https://opendal.apache.org' },
  { label: 'SQLite FTS5', href: 'https://sqlite.org/fts5.html' },
  { label: 'rmcp', href: 'https://github.com/modelcontextprotocol/rust-sdk' },
];
---
<footer class="footer section-pad" role="contentinfo">
  <div class="footer-inner">
    <div class="footer-grid">
      <!-- Brand column -->
      <div class="footer-brand">
        <div class="brand-name">Gradatum</div>
        <div class="eyebrow brand-tagline">memoria · gradatim · per gradus</div>
        <p class="brand-desc">
          Apache-2.0 · Open source — alpha, API not stable before v1.0.
          Source on <a href="https://github.com/gradatum/gradatum" target="_blank" rel="noopener noreferrer">GitHub</a> ·
          packages on <a href="https://crates.io/crates/gradatum" target="_blank" rel="noopener noreferrer">crates.io</a>.
        </p>
      </div>

      <!-- Pages column -->
      <div class="footer-col">
        <div class="eyebrow col-head">Pages</div>
        <ul role="list">
          <li><a href="/vault">Vault</a></li>
          <li><a href="/features">Features</a></li>
          <li><a href="/install">Install</a></li>
          <li><a href="/use-cases">Use cases</a></li>
        </ul>
      </div>

      <!-- Project column -->
      <div class="footer-col">
        <div class="eyebrow col-head">Project</div>
        <ul role="list">
          <li><a href="https://github.com/gradatum/gradatum" target="_blank" rel="noopener noreferrer">GitHub</a></li>
          <li><a href="https://crates.io/crates/gradatum" target="_blank" rel="noopener noreferrer">crates.io</a></li>
          <li><span class="footer-text-muted">License — Apache-2.0</span></li>
        </ul>
      </div>

      <!-- Stack column -->
      <div class="footer-col">
        <div class="eyebrow col-head">Stack</div>
        <ul role="list">
          {stackLinks.map(({ label, href }) => (
            <li>
              <a href={href} target="_blank" rel="noopener noreferrer">{label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {YEAR} Gradatum maintainers · Apache-2.0</span>
      <span>gradatum now primary · <a href="https://gradatum.org">gradatum.org</a></span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg);
    border-top: 1px solid var(--rule);
    padding-top: 3rem;
    padding-bottom: 4rem;
  }

  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
  }

  .footer-text-muted {
    font-size: 0.875rem;
    color: var(--muted);
    cursor: default;
    font-style: italic;
  }

  .brand-name {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-style: italic;
    font-weight: 400;
    color: var(--ink);
  }

  .brand-tagline {
    margin-top: 0.5rem;
    color: var(--muted);
  }

  .brand-desc {
    margin-top: 1rem;
    font-size: 0.875rem;
    color: var(--ink-soft);
    max-width: 22rem;
    line-height: 1.65;
  }

  .brand-desc a {
    color: var(--ink-soft);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.15s ease;
  }

  .brand-desc a:hover {
    color: var(--accent);
  }

  .col-head {
    letter-spacing: 0.18em;
    margin-bottom: 0.875rem;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-col a {
    font-size: 0.875rem;
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-col a:hover {
    color: var(--ink);
  }

  .footer-bottom {
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-bottom a {
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-bottom a:hover {
    color: var(--accent);
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
    }
  }
</style>
