---
const GITHUB_URL = 'https://github.com/mymomot/gradatum';
const YEAR = new Date().getFullYear();

const docLinks = [
  { label: 'README', href: `${GITHUB_URL}#readme` },
  { label: 'ARCHITECTURE.md', href: `${GITHUB_URL}/blob/main/ARCHITECTURE.md` },
  { label: 'docs/PHASES.md', href: `${GITHUB_URL}/blob/main/docs/PHASES.md` },
  { label: 'docs/BENCH.md', href: `${GITHUB_URL}/blob/main/docs/BENCH.md` },
];

const projectLinks = [
  { label: 'GitHub', href: GITHUB_URL },
  { label: 'Issues', href: `${GITHUB_URL}/issues` },
  { label: 'Releases', href: `${GITHUB_URL}/releases` },
  { label: 'License', href: `${GITHUB_URL}/blob/main/LICENSE` },
  { label: 'CONTRIBUTING.md', href: `${GITHUB_URL}/blob/main/CONTRIBUTING.md` },
];

const relatedLinks = [
  { label: 'mycelium-io', href: 'https://github.com/mycelium-io/mycelium' },
  { label: 'mem0', href: 'https://github.com/mem0ai/mem0' },
  { label: 'Cognee', href: 'https://github.com/topoteretes/cognee' },
  { label: 'Apache OpenDAL', href: 'https://opendal.apache.org' },
];
---
<footer class="footer section-pad" role="contentinfo">
  <div class="footer-inner">
    <div class="footer-grid">
      <!-- Brand column -->
      <div class="footer-brand">
        <div class="brand-name">Gradatum</div>
        <div class="eyebrow brand-tagline">memoria · gradatim · per gradus</div>
        <p class="brand-desc">
          Apache-2.0. Built openly. Alpha — under construction.
          Built on lessons from a private predecessor.
          PRs welcome.
        </p>
      </div>

      <!-- Docs column -->
      <div class="footer-col">
        <div class="eyebrow col-head">Docs</div>
        <ul role="list">
          {docLinks.map(({ label, href }) => (
            <li>
              <a href={href} target="_blank" rel="noopener noreferrer">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Project column -->
      <div class="footer-col">
        <div class="eyebrow col-head">Project</div>
        <ul role="list">
          {projectLinks.map(({ label, href }) => (
            <li>
              <a href={href} target="_blank" rel="noopener noreferrer">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Related column -->
      <div class="footer-col">
        <div class="eyebrow col-head">Related</div>
        <ul role="list">
          {relatedLinks.map(({ label, href }) => (
            <li>
              <a href={href} target="_blank" rel="noopener noreferrer">{label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {YEAR} Gradatum maintainers · Apache-2.0</span>
      <span>built on lessons from a private predecessor · <a href="https://gradatum.org">gradatum.org</a></span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--bg);
    border-top: 1px solid var(--rule);
    padding-top: 3rem;
    padding-bottom: 4rem;
  }

  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
  }

  .brand-name {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-style: italic;
    font-weight: 400;
    color: var(--ink);
  }

  .brand-tagline {
    margin-top: 0.5rem;
    color: var(--muted);
  }

  .brand-desc {
    margin-top: 1rem;
    font-size: 0.875rem;
    color: var(--ink-soft);
    max-width: 22rem;
    line-height: 1.65;
  }

  .col-head {
    letter-spacing: 0.18em;
    margin-bottom: 0.875rem;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-col a {
    font-size: 0.875rem;
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-col a:hover {
    color: var(--ink);
  }

  .footer-bottom {
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-bottom a {
    color: var(--muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-bottom a:hover {
    color: var(--accent);
  }

  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }

    .footer-brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 480px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      flex-direction: column;
    }
  }
</style>
