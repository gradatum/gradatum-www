---
// Data import triggers Zod .parse() at build time (fail-fast validation)
import { useCases } from '../data/usecases';

// Silence unused-variable warning — imported for build-time Zod validation
void useCases;

import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import UseCasesSection from '../components/UseCasesSection.astro';
import Footer from '../components/Footer.astro';
import TweaksPanel from '../components/TweaksPanel.astro';
---
<Base
  title="Use Cases — Gradatum"
  description="Eight concrete scenarios where persistent memory changes how operators and agents work together."
>
  <div class="site-wrap">
    <Nav />

    <main id="main-content" tabindex="-1">
      <UseCasesSection />
    </main>

    <Footer />

    <TweaksPanel />
  </div>

  <a href="#main-content" class="skip-link">Skip to main content</a>
</Base>

<style>
  .site-wrap {
    max-width: 1280px;
    margin: 0 auto;
    background: var(--paper);
    box-shadow: 0 0 0 1px var(--rule);
  }

  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    background: var(--accent);
    color: var(--paper);
    padding: 0.75rem 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    z-index: 9999;
    text-decoration: none;
  }

  .skip-link:focus {
    top: 0.5rem;
  }
</style>
