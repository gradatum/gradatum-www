---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import AgentLayerStack from '../components/AgentLayerStack.astro';
import Footer from '../components/Footer.astro';
import TweaksPanel from '../components/TweaksPanel.astro';
---
<Base
  title="Gradatum — Agent Layer"
  description="The agent layer for gradatum: compute backbone (gateway + engine fleet) live since v0.3.0. Agent runtime — context assembly, ReAct loop, skill selection — coming v0.6.0."
>
  <div class="site-wrap">
    <Nav />

    <main id="main-content" tabindex="-1">

      <!-- ── Hero ── -->
      <section class="agent-hero section-pad" aria-labelledby="agent-hero-title">
        <div class="agent-hero-inner">
          <div class="eyebrow">Gradatum · Agent Layer</div>
          <h1 id="agent-hero-title" class="agent-hero-h1">
            Foundations first.<br />
            <em class="accent-italic">Runtime</em> next.
          </h1>
          <p class="agent-hero-desc">
            Two of the three layers that make a self-hosted agent stack are already in place.
            The memory store and the compute backbone are live — sovereign, embedded, no SaaS round-trip.
            The agent runtime that orchestrates them comes with v0.6.0.
          </p>
          <div class="agent-hero-status">
            <span class="status-chip status-chip-live">
              <span class="chip-dot chip-dot-live" aria-hidden="true"></span>
              Memory + Compute live
            </span>
            <span class="status-chip status-chip-coming">
              <span class="chip-dot chip-dot-coming" aria-hidden="true"></span>
              Runtime · v0.6.0
            </span>
          </div>
        </div>
      </section>

      <hr class="rule" />

      <!-- ── Stack diagram ── -->
      <AgentLayerStack />

      <hr class="rule" />

      <!-- ── Foundations deep-dive ── -->
      <section class="foundations section-pad" aria-labelledby="foundations-title">
        <div class="foundations-inner">
          <div class="eyebrow">Live since v0.3.0</div>
          <h2 id="foundations-title" class="foundations-h2">
            Two foundations.<br />
            <em class="accent-italic">Already in place.</em>
          </h2>
          <p class="foundations-intro">
            The runtime coming in v0.6.0 builds on two live components — a compute layer for
            inference routing, and a memory layer for persistent knowledge. Both are sovereign,
            embedded, and running today.
          </p>

          <!-- ── Foundation: Compute ── -->
          <div class="compute-block">
            <header class="block-header">
              <div class="block-status-row">
                <span class="fstatus-dot fstatus-live" aria-hidden="true"></span>
                <span class="fstatus-label">LIVE</span>
                <span class="block-layer-tag">Compute</span>
              </div>
            </header>

            <div class="compute-sub-grid">

              <!-- Bloc A — Gateway -->
              <article class="compute-card" aria-labelledby="gateway-title">
                <div class="cc-eyebrow">Gateway — unified LLM router</div>
                <h3 id="gateway-title" class="cc-title">Gateway</h3>
                <div class="cc-axes">

                  <div class="cc-axis">
                    <div class="cc-axis-label">Context</div>
                    <p class="cc-axis-text">OpenAI-compatible Chat Completions — multi-turn, multimodal content (text + base64 images), tool-calling, SSE streaming. Semantic reranking and embeddings as native endpoints.</p>
                  </div>

                  <div class="cc-axis">
                    <div class="cc-axis-label">Routing &amp; fallback</div>
                    <p class="cc-axis-text">Each model alias maps to a primary backend with an optional configurable fallback. A per-provider circuit-breaker (closed / open / half-open) trips on transient errors, and a smart router applies per-context defaults or header-driven overrides.</p>
                  </div>

                  <div class="cc-axis">
                    <div class="cc-axis-label">Logs</div>
                    <p class="cc-axis-text">Every LLM call is recorded in an append-only journal — alias, effective provider, route, latency, tokens, HTTP code, role id — with 30-day retention, a 5M-event cap, and Prometheus export. Conversation content is never captured.</p>
                  </div>

                  <div class="cc-axis">
                    <div class="cc-axis-label">Identity</div>
                    <p class="cc-axis-text">Endpoints are guarded by Bearer token with constant-time comparison and an optional loopback bypass keyed on the real TCP address. Business-context ids (feature, agent) are propagated into telemetry — never exposed in logs.</p>
                  </div>

                </div>
              </article>

              <!-- Bloc B — Engine fleet -->
              <article class="compute-card" aria-labelledby="engine-fleet-title">
                <div class="cc-eyebrow">Engine fleet — local inference</div>
                <h3 id="engine-fleet-title" class="cc-title">Engine fleet</h3>
                <div class="cc-axes">

                  <div class="cc-axis">
                    <div class="cc-axis-label">Optimization</div>
                    <p class="cc-axis-text">A native Rust supervisor runs inference processes directly — managing GPU, context window, slot parallelism and sampling per model instance, under strict execution-environment isolation and graceful shutdown.</p>
                  </div>

                  <div class="cc-axis">
                    <div class="cc-axis-label">Monitoring</div>
                    <p class="cc-axis-text">Each inference instance exposes a real-time health endpoint (starting / ok / unhealthy) and Prometheus metrics (requests, latencies), with automatic supervision under a bounded restart budget and flapping detection.</p>
                  </div>

                  <div class="cc-axis">
                    <div class="cc-axis-label">Shared config &amp; logs</div>
                    <p class="cc-axis-text">Per-instance configuration is declarative TOML with environment overrides. Every request emits an async, non-blocking telemetry event (route, model, latency, HTTP code, role id) to the central journal — engine and server share the same core types and auth handshake.</p>
                  </div>

                </div>
              </article>

            </div>
          </div>

          <!-- ── Foundation: Memory (compact) ── -->
          <div class="memory-compact-block">
            <div class="memory-compact-inner">
              <div class="mcb-left">
                <div class="block-status-row">
                  <span class="fstatus-dot fstatus-live" aria-hidden="true"></span>
                  <span class="fstatus-label">LIVE</span>
                  <span class="block-layer-tag">Memory</span>
                </div>
                <h3 class="mcb-title">Vault</h3>
                <p class="mcb-desc">
                  Sovereign knowledge store — BM25 + cosine + RRF, MCP, history, temporal index.
                </p>
              </div>
              <div class="mcb-right">
                <a href="/vault" class="vault-ref-link" aria-label="Explore the memory layer in depth on the Vault page">
                  the memory layer →&nbsp;/vault
                </a>
              </div>
            </div>
          </div>

        </div>
      </section>

      <hr class="rule" />

      <!-- ── Roadmap runtime ── -->
      <section class="runtime-roadmap section-pad" aria-labelledby="runtime-roadmap-title">
        <div class="runtime-roadmap-inner">
          <div class="eyebrow">Roadmap · v0.6.0</div>
          <h2 id="runtime-roadmap-title" class="runtime-h2">
            The agent runtime.<br />
            <em class="accent-italic">What comes next.</em>
          </h2>
          <p class="runtime-desc">
            With the memory store and compute backbone already in place, v0.6.0 adds the orchestration
            layer — the code that consumes both foundations to run autonomous agent loops.
          </p>

          <div class="runtime-items">

            <div class="runtime-item">
              <div class="ri-header">
                <span class="ri-badge">coming</span>
                <h3 class="ri-title">Context assembly</h3>
              </div>
              <p class="ri-desc">
                Sliding-window continuity over the conversation, combined with proactive recall
                from the Vault — relevant memories injected at the right moment, not on every turn.
              </p>
            </div>

            <div class="runtime-item">
              <div class="ri-header">
                <span class="ri-badge">coming</span>
                <h3 class="ri-title">ReAct runtime</h3>
              </div>
              <p class="ri-desc">
                Agent loop with tool dispatch via MCP, built-in guards against runaway loops,
                and structured observation → thought → action traces for auditability.
              </p>
            </div>

            <div class="runtime-item">
              <div class="ri-header">
                <span class="ri-badge">coming</span>
                <h3 class="ri-title">Skill selection</h3>
              </div>
              <p class="ri-desc">
                MCP-native dispatch matched to agent intent. The gateway routes to the right
                engine role; the skill layer decides which capability to invoke.
              </p>
            </div>

          </div>

          <p class="runtime-note">
            All three components build on the foundations already LIVE.
            No new storage engine, no new inference stack — the same discipline, extended upward.
          </p>
        </div>
      </section>

    </main>

    <Footer />

    <!-- Tweaks panel — island (JS enabled) -->
    <TweaksPanel />
  </div>

  <!-- Skip to content link (accessibility) -->
  <a href="#main-content" class="skip-link">Skip to main content</a>
</Base>

<style>
  .site-wrap {
    max-width: 1280px;
    margin: 0 auto;
    background: var(--paper);
    box-shadow: 0 0 0 1px var(--rule);
  }

  /* ───── Hero ───── */
  .agent-hero {
    padding-top: 6rem;
    padding-bottom: 5rem;
  }

  .agent-hero-inner {
    max-width: 880px;
  }

  .agent-hero-h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 500;
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 1.25rem 0 1.75rem;
  }

  .accent-italic {
    font-style: italic;
    color: var(--accent);
    font-weight: 600;
  }

  .agent-hero-desc {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--ink-soft);
    max-width: 680px;
    margin-bottom: 2.5rem;
  }

  .agent-hero-status {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .status-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.875rem;
    border: 1px solid var(--rule);
    border-radius: 2px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .status-chip-live {
    border-color: color-mix(in srgb, var(--accent) 40%, var(--rule));
    color: var(--ink);
  }

  .status-chip-coming {
    color: var(--muted);
    opacity: 0.8;
  }

  .chip-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .chip-dot-live {
    background: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 20%, transparent);
  }

  .chip-dot-coming {
    background: transparent;
    border: 1.5px dashed var(--muted);
    opacity: 0.6;
  }

  /* ───── Foundations deep-dive ───── */
  .foundations-inner {
    max-width: 1080px;
  }

  .foundations-h2 {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.015em;
    margin: 1rem 0 1.25rem;
  }

  .foundations-intro {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--ink-soft);
    max-width: 680px;
    margin-bottom: 3.5rem;
  }

  /* ── Shared status row ── */
  .block-status-row {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .fstatus-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .fstatus-live {
    background: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 20%, transparent);
  }

  .fstatus-label {
    color: var(--accent);
  }

  .block-layer-tag {
    color: var(--muted);
    padding-left: 0.5rem;
    border-left: 1px solid var(--rule);
    margin-left: 0.25rem;
  }

  /* ── Compute block ── */
  .compute-block {
    border: 1px solid var(--accent);
    background: color-mix(in srgb, var(--accent) 3%, var(--paper));
    padding: 2.25rem;
    margin-bottom: 1.5rem;
  }

  .block-header {
    margin-bottom: 2rem;
  }

  .compute-sub-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  /* ── Compute cards (Gateway / Engine fleet) ── */
  .compute-card {
    border: 1px solid var(--rule);
    background: var(--paper);
    padding: 1.75rem;
  }

  .cc-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.6rem;
  }

  .cc-title {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 2.5vw, 1.625rem);
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0 0 1.5rem;
  }

  /* ── Axes grid (2-col where space allows) ── */
  .cc-axes {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .cc-axis {
    border-top: 2px solid var(--rule);
    padding-top: 0.875rem;
  }

  .cc-axis-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .cc-axis-text {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--ink-soft);
  }

  /* Engine fleet — 3 axes: last one spans full width on 2-col */
  .compute-card:last-child .cc-axes {
    grid-template-columns: 1fr 1fr;
  }

  .compute-card:last-child .cc-axis:last-child {
    grid-column: 1 / -1;
  }

  /* ── Memory compact block ── */
  .memory-compact-block {
    border: 1px solid var(--rule);
    border-left: 3px solid var(--accent);
    background: var(--paper);
    padding: 1.75rem 2rem;
  }

  .memory-compact-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .mcb-left {
    flex: 1;
    min-width: 200px;
  }

  .mcb-title {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 2.5vw, 1.625rem);
    font-weight: 500;
    letter-spacing: -0.01em;
    margin: 0.375rem 0 0.625rem;
  }

  .mcb-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 520px;
  }

  .mcb-right {
    flex-shrink: 0;
  }

  .vault-ref-link {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
    letter-spacing: 0.06em;
    text-decoration: none;
    font-weight: 500;
    transition: opacity 0.15s ease;
    white-space: nowrap;
  }

  .vault-ref-link:hover {
    opacity: 0.75;
  }

  .vault-ref-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 2px;
  }

  /* ───── Runtime roadmap ───── */
  .runtime-roadmap {
    background: var(--bg);
    border-top: 1px solid var(--rule);
  }

  .runtime-roadmap-inner {
    max-width: 1080px;
  }

  .runtime-h2 {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    line-height: 1.1;
    letter-spacing: -0.015em;
    margin: 1rem 0 1.75rem;
  }

  .runtime-desc {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--ink-soft);
    max-width: 680px;
    margin-bottom: 3rem;
  }

  .runtime-items {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .runtime-item {
    border: 1px solid var(--rule);
    border-top: 2px dashed var(--muted);
    padding: 1.75rem;
    background: var(--paper);
    opacity: 0.85;
  }

  .ri-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.875rem;
  }

  .ri-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px dashed var(--muted);
    padding: 0.15rem 0.5rem;
    opacity: 0.75;
    flex-shrink: 0;
  }

  .ri-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--ink-soft);
    margin: 0;
  }

  .ri-desc {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--muted);
  }

  .runtime-note {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-height: 1.6;
    color: var(--muted);
    max-width: 640px;
    padding: 1rem 1.25rem;
    border-left: 2px solid var(--rule);
    letter-spacing: 0.03em;
  }

  /* ───── Skip link ───── */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    background: var(--accent);
    color: var(--paper);
    padding: 0.75rem 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    z-index: 9999;
    text-decoration: none;
  }

  .skip-link:focus {
    top: 0.5rem;
  }

  /* ───── Responsive ───── */
  @media (max-width: 900px) {
    .compute-sub-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .cc-axes {
      grid-template-columns: 1fr;
    }

    .compute-card:last-child .cc-axis:last-child {
      grid-column: auto;
    }

    .runtime-items {
      grid-template-columns: 1fr;
    }

    .agent-hero-status {
      flex-direction: column;
      gap: 0.5rem;
    }

    .memory-compact-inner {
      flex-direction: column;
      gap: 1.25rem;
      align-items: flex-start;
    }

    .compute-block {
      padding: 1.5rem 1.25rem;
    }
  }

  @media (max-width: 600px) {
    .cc-axes {
      grid-template-columns: 1fr;
    }
  }
</style>
